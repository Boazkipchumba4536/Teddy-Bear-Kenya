{
  "name": "teddy-bear-kenya",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3001",
    "clean": "node scripts/kill-dev-ports.mjs && node scripts/clean-next-cache.mjs",
    "dev:clean": "npm run clean && next dev -p 3001",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "seed:supabase": "node scripts/seed-supabase.mjs",
    "catalog:fetch": "node scripts/fetch-littleteddy-catalog.mjs",
    "catalog:fetch-tambo": "node scripts/fetch-tambo-catalog.mjs",
    "catalog:enrich-images": "node scripts/enrich-catalog-images.mjs",
    "catalog:import": "node scripts/import-littleteddy-catalog.mjs",
    "catalog:import-tambo": "node scripts/import-tambo-catalog.mjs",
    "catalog:sync": "node scripts/enrich-catalog-images.mjs && node scripts/import-littleteddy-catalog.mjs",
    "catalog:sync-tambo": "node scripts/fetch-tambo-catalog.mjs && node scripts/import-tambo-catalog.mjs",
    "catalog:fix-images": "node scripts/fix-product-images.mjs",
    "catalog:dedupe": "node scripts/dedupe-products.mjs",
    "catalog:dedupe:apply": "node scripts/dedupe-products.mjs --delete",
    "catalog:sync-public-images": "node scripts/sync-public-product-images.mjs"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.4.0",
    "@supabase/ssr": "^0.10.3",
    "@supabase/supabase-js": "^2.106.2",
    "framer-motion": "^12.40.0",
    "lucide-react": "^0.460.0",
    "next": "^14.2.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "react-hook-form": "^7.77.0",
    "zod": "^4.4.3",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.15",
    "typescript": "^5.6.0"
  }
}
